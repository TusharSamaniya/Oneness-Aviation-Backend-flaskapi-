# ── App ───────────────────────────────────────────────────────────────────────
APP_NAME="Oneness Aviation"
APP_ENV=development          # development | production
DEBUG=true
FRONTEND_URL=http://localhost:5173

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/oneness_db

# ── Auth ──────────────────────────────────────────────────────────────────────
SECRET_KEY=your-super-secret-key-change-this-in-production-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Email (use Gmail App Password or SendGrid/Brevo) ──────────────────────────
MAIL_USERNAME=fly@onenessaviation.com
MAIL_PASSWORD=your-email-app-password
MAIL_FROM=fly@onenessaviation.com
MAIL_FROM_NAME=Oneness Aviation
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_STARTTLS=true
MAIL_SSL_TLS=false

# ── Admin notification email ──────────────────────────────────────────────────
ADMIN_EMAIL=admin@onenessaviation.com

# ── Razorpay ─────────────────────────────────────────────────────────────────
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your-razorpay-secret

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── AWS S3 / Cloudflare R2 ───────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_S3_BUCKET=oneness-aviation-media
AWS_S3_REGION=ap-south-1

# ── Sentry ───────────────────────────────────────────────────────────────────
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
